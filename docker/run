#!/bin/sh
xhost +

EXTRA_MOUNTS=""
if [ -n "$REAPER_PROJECTS_DIR" ]; then
    EXTRA_MOUNTS="$EXTRA_MOUNTS -v $REAPER_PROJECTS_DIR:/proj"
fi
if [ -n "$REAPER_MEDIA_DIR" ]; then
    EXTRA_MOUNTS="$EXTRA_MOUNTS -v $REAPER_MEDIA_DIR:/media"
fi

docker run \
    -it \
    --rm \
    --name reaper \
    --network=none \
    -u $(id -u):$(id -g) \
    --ipc=host \
    --cap-add=sys_nice \
    --ulimit rtprio=99  \
    --group-add 17 \
    --device /dev/snd \
    -e PULSE_SERVER=unix:/tmp/pulse/native \
    -e DISPLAY=$DISPLAY \
    -e HOME=$HOME \
    -e XDG_RUNTIME_DIR=/tmp \
    -e QT_X11_NO_MITSHM=1 \
    -v /tmp/.X11-unix:/tmp/.X11-unix:rw \
    -v /etc/passwd:/etc/passwd:ro \
    -v /etc/group:/etc/group:ro \
    -v $(pwd):/cwd \
    -v $XDG_RUNTIME_DIR/pipewire-0:/tmp/pipewire-0 \
    -v $XDG_RUNTIME_DIR/pulse:/tmp/pulse \
    -v $HOME/.config/REAPER:$HOME/.config/REAPER \
    $EXTRA_MOUNTS \
    -w /app \
    reaper:latest
