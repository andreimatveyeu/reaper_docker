#!/bin/sh
xhost +

# Optional host-side hooks run around the container:
#   REAPER_PRE_HOOK  - shell command run before the container starts
#   REAPER_POST_HOOK - shell command run after the container exits
# Both are optional; when unset, nothing extra runs.
if [ -n "$REAPER_PRE_HOOK" ]; then
    echo "run: executing pre-hook" >&2
    sh -c "$REAPER_PRE_HOOK"
fi

# Run the post-hook on exit (normal or interrupted), even if docker run fails.
if [ -n "$REAPER_POST_HOOK" ]; then
    trap 'echo "run: executing post-hook" >&2; sh -c "$REAPER_POST_HOOK"' EXIT
fi

EXTRA_MOUNTS=""
if [ -n "$REAPER_PROJECTS_DIR" ]; then
    EXTRA_MOUNTS="$EXTRA_MOUNTS -v $REAPER_PROJECTS_DIR:/proj"
fi
if [ -n "$REAPER_MEDIA_DIR" ]; then
    EXTRA_MOUNTS="$EXTRA_MOUNTS -v $REAPER_MEDIA_DIR:/media"
fi

docker run \
    -it \
    --rm \
    --name reaper \
    --network=none \
    -u $(id -u):$(id -g) \
    --ipc=host \
    --cap-add=sys_nice \
    --ulimit rtprio=99  \
    --group-add 17 \
    --device /dev/snd \
    -e PULSE_SERVER=unix:/tmp/pulse/native \
    -e DISPLAY=$DISPLAY \
    -e HOME=$HOME \
    -e XDG_RUNTIME_DIR=/tmp \
    -e QT_X11_NO_MITSHM=1 \
    -v /tmp/.X11-unix:/tmp/.X11-unix:rw \
    -v /etc/passwd:/etc/passwd:ro \
    -v /etc/group:/etc/group:ro \
    -v $(pwd):/cwd \
    -v $XDG_RUNTIME_DIR/pipewire-0:/tmp/pipewire-0 \
    -v $XDG_RUNTIME_DIR/pulse:/tmp/pulse \
    -v $HOME/.config/REAPER:$HOME/.config/REAPER \
    $EXTRA_MOUNTS \
    -w /app \
    reaper:latest
